# ── OpenRouter (chat completion) ────────────────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model id on OpenRouter. Some good defaults:
#   openai/gpt-4o-mini              — cheap, fast, reliable
#   anthropic/claude-3.5-haiku      — strong reasoning
#   meta-llama/llama-3.3-70b-instruct:free — free tier
OPENROUTER_MODEL=openai/gpt-4o-mini

# Public site URL — sent to OpenRouter for analytics; not required.
SITE_URL=http://localhost:3000

# ── Embeddings ──────────────────────────────────────────────────
# OpenRouter does NOT support embeddings, so we run a small model
# locally via @xenova/transformers. No key needed.
# Override only if you want a different HF model id.
EMBED_MODEL=Xenova/all-MiniLM-L6-v2

# ── Qdrant (vector store) ───────────────────────────────────────
# Local docker:  http://localhost:6333  (no API key)
# Qdrant Cloud:  https://<cluster>.qdrant.tech:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
